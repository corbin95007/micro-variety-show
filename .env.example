SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 固定生产前端域名；服务端邮件回调只会重定向到此 origin 下的安全路径
# 生产必须使用 https://；本地开发只允许 http://localhost 或 http://127.0.0.1
APP_BASE_URL=https://your-site.example.com
# 必填：服务端 auth callback 与 recovery consume 共用的长随机密钥，用于签名重置密码 handoff
AUTH_HANDOFF_SECRET=replace-with-a-long-random-secret
ALIPAY_NOTIFY_BASE_URL=https://your-site.example.com
ALIPAY_NOTIFY_URL=https://your-site.example.com/api/payment/notify/alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-app-private-key
ALIPAY_APP_PUBLIC_KEY=your-app-public-key
ALIPAY_PUBLIC_KEY=your-alipay-platform-public-key
ALIPAY_SELLER_ID=your-seller-id
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 支付 provider 开关：默认由服务端决定；切到七相时填 payqixiang，回滚支付宝时填 alipay
PAYMENT_ACTIVE_PROVIDER=payqixiang
# 七相聚合支付服务端变量。KEY 只能放服务端环境变量，不能使用 VITE_ 前缀。
QIXIANG_PID=your-qixiang-merchant-pid
QIXIANG_KEY=your-qixiang-merchant-key
QIXIANG_API_URL=https://api.payqixiang.cn/mapi.php
QIXIANG_QUERY_URL=https://api.payqixiang.cn/api.php
# 正式商户小额真实收款测试开关：1 = 0.01 元；上线恢复为空或删除，走正式商品金额
PAYMENT_TEST_AMOUNT_CENTS=1
EPISODE_ONE_AIRED=false
VITE_XIAOHONGSHU_OFFICIAL_URL=https://your-xiaohongshu-official-url.example.com
VITE_DOUYIN_OFFICIAL_URL=https://your-douyin-official-url.example.com
FEEDBACK_ADMIN_EMAIL=admin@example.com
FEEDBACK_FROM_EMAIL=your-gmail@gmail.com
GMAIL_SMTP_USER=your-gmail@gmail.com
GMAIL_SMTP_APP_PASSWORD=your-google-app-password
FEEDBACK_SITE_NAME=微综艺测试网站
