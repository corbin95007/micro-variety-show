SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 固定生产前端域名；服务端邮件回调只会重定向到此 origin 下的安全路径
# 生产必须使用 https://；本地开发只允许 http://localhost 或 http://127.0.0.1
APP_BASE_URL=https://your-site.example.com
# 必填：服务端 auth callback 与 recovery consume 共用的长随机密钥，用于签名重置密码 handoff
AUTH_HANDOFF_SECRET=replace-with-a-long-random-secret
ALIPAY_NOTIFY_BASE_URL=https://your-site.example.com
ALIPAY_NOTIFY_URL=https://your-site.example.com/api/payment/notify/alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-app-private-key
ALIPAY_APP_PUBLIC_KEY=your-app-public-key
ALIPAY_PUBLIC_KEY=your-alipay-platform-public-key
ALIPAY_SELLER_ID=your-seller-id
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
EPISODE_ONE_AIRED=false
